package com.soundwave.app.data

import okhttp3.OkHttpClient
import okhttp3.Request
import org.json.JSONArray
import org.json.JSONObject
import kotlin.coroutines.resume
import kotlin.coroutines.resumeWithException
import kotlinx.coroutines.suspendCancellableCoroutine
import java.util.concurrent.TimeUnit
import javax.crypto.Cipher
import javax.crypto.spec.SecretKeySpec

/**
 * All music data comes directly from JioSaavn's own production API
 * (www.jiosaavn.com/api.php) — the same backend the official JioSaavn
 * app uses. No third-party wrapper servers involved, so there's no
 * rate-limiting or downtime dependency on anyone else's infrastructure.
 *
 * Stream URLs are returned encrypted (encrypted_media_url field) using
 * DES/ECB/PKCS5Padding with the fixed key "38346591". We decrypt them
 * using Java's built-in javax.crypto — no extra library needed.
 */

data class Song(
    val id: String,
    val title: String,
    val artist: String,
    val album: String?,
    val thumbnail: String?,
    val durationSec: Int,
    val streamUrl: String?,
    val source: String = "jiosaavn"
)

object SaavnApi {
    private const val BASE = "https://www.jiosaavn.com/api.php"
    private const val DES_KEY = "38346591"

    private val client = OkHttpClient.Builder()
        .connectTimeout(15, TimeUnit.SECONDS)
        .readTimeout(20, TimeUnit.SECONDS)
        .build()

    // ── HTTP ───────────────────────────────────────────────────────────────────

    private suspend fun getJson(url: String): JSONObject = suspendCancellableCoroutine { cont ->
        val request = Request.Builder()
            .url(url)
            .header("User-Agent", "Mozilla/5.0 (Linux; Android 10)")
            .header("Accept", "application/json")
            .build()
        client.newCall(request).enqueue(object : okhttp3.Callback {
            override fun onFailure(call: okhttp3.Call, e: java.io.IOException) {
                if (cont.isActive) cont.resumeWithException(e)
            }
            override fun onResponse(call: okhttp3.Call, response: okhttp3.Response) {
                try {
                    val body = response.body?.string() ?: "{}"
                    if (cont.isActive) cont.resume(JSONObject(body))
                } catch (e: Exception) {
                    if (cont.isActive) cont.resumeWithException(e)
                }
            }
        })
    }

    // ── DES Decryption ─────────────────────────────────────────────────────────

    /**
     * Decrypts JioSaavn's encrypted_media_url.
     * Algorithm: DES/ECB/PKCS5Padding, key "38346591"
     * This is the same decryption the official app performs internally.
     */
    private fun decryptUrl(encrypted: String): String {
        val keySpec = SecretKeySpec(DES_KEY.toByteArray(Charsets.UTF_8), "DES")
        val cipher = Cipher.getInstance("DES/ECB/PKCS5Padding")
        cipher.init(Cipher.DECRYPT_MODE, keySpec)
        val decoded = android.util.Base64.decode(encrypted.trim(), android.util.Base64.DEFAULT)
        return String(cipher.doFinal(decoded), Charsets.UTF_8)
    }

    private fun bestStreamUrl(data: JSONObject): String? {
        // Prefer 320kbps if available, fall back to 160kbps
        val encrypted = data.optString("encrypted_media_url", "")
            .takeIf { it.isNotBlank() } ?: return null
        return try {
            val decrypted = decryptUrl(encrypted)
            if (data.optString("320kbps") == "true") {
                decrypted.replace("_96.mp4", "_320.mp4")
                    .replace("_160.mp4", "_320.mp4")
            } else {
                decrypted.replace("_96.mp4", "_160.mp4")
            }
        } catch (e: Exception) { null }
    }

    // ── Search ─────────────────────────────────────────────────────────────────

    suspend fun search(query: String): List<Song> {
        val encoded = java.net.URLEncoder.encode(query, "UTF-8")
        // search.getResults is JioSaavn's full paginated search — returns
        // proper ranked results for all languages (Telugu, Hindi, English)
        val url = "$BASE?__call=search.getResults&_format=json&_marker=0&cc=in&includeMetaTags=1&q=$encoded&n=20&p=1"
        return try {
            val json = getJson(url)
            val results = json.optJSONArray("results") ?: return emptyList()
            parseSongArray(results)
        } catch (e: Exception) { emptyList() }
    }

    // ── Song by ID ─────────────────────────────────────────────────────────────

    suspend fun getSongById(id: String): Song? {
        if (id.startsWith("direct_")) return getSongByRawId(id.removePrefix("direct_"))
        return getSongByRawId(id)
    }

    private suspend fun getSongByRawId(id: String): Song? {
        return try {
            val url = "$BASE?__call=song.getDetails&cc=in&_marker=0&_format=json&pids=$id"
            val json = getJson(url)
            val data = json.optJSONObject(id) ?: return null
            parseSongObject(id, data)
        } catch (e: Exception) { null }
    }

    // ── Album ──────────────────────────────────────────────────────────────────

    data class AlbumResult(val id: String, val name: String, val artist: String, val thumbnail: String?)

    suspend fun searchAlbums(query: String): List<AlbumResult> {
        val encoded = java.net.URLEncoder.encode(query, "UTF-8")
        val url = "$BASE?__call=search.getAlbumResults&_format=json&_marker=0&cc=in&q=$encoded&n=15"
        return try {
            val json = getJson(url)
            val results = json.optJSONArray("results") ?: return emptyList()
            val list = mutableListOf<AlbumResult>()
            for (i in 0 until results.length()) {
                val o = results.optJSONObject(i) ?: continue
                val albumId = o.optString("albumid", "").takeIf { it.isNotBlank() } ?: continue
                val name = htmlDecode(o.optString("album", ""))
                val artist = htmlDecode(o.optString("primary_artists", ""))
                val image = o.optString("image", "").replace("150x150", "500x500")
                list.add(AlbumResult(albumId, name, artist, image.ifBlank { null }))
            }
            list
        } catch (e: Exception) { emptyList() }
    }

    suspend fun getAlbumSongs(albumId: String): List<Song> {
        return try {
            val url = "$BASE?__call=content.getAlbumDetails&_format=json&_marker=0&cc=in&albumid=$albumId"
            val json = getJson(url)
            val songs = json.optJSONArray("songs") ?: return emptyList()
            parseSongArray(songs)
        } catch (e: Exception) { emptyList() }
    }

    // ── Parsers ────────────────────────────────────────────────────────────────

    private fun parseSongArray(arr: JSONArray): List<Song> {
        val list = mutableListOf<Song>()
        for (i in 0 until arr.length()) {
            val o = arr.optJSONObject(i) ?: continue
            val id = o.optString("id", "").takeIf { it.isNotBlank() } ?: continue
            val song = parseSongObject(id, o) ?: continue
            list.add(song)
        }
        return list
    }

    private fun parseSongObject(id: String, o: JSONObject): Song? {
        val title = htmlDecode(o.optString("song", o.optString("title", ""))).takeIf { it.isNotBlank() } ?: return null
        val artist = htmlDecode(o.optString("primary_artists", o.optString("singers", "Unknown Artist")))
        val album = htmlDecode(o.optString("album", "")).ifBlank { null }
        val image = o.optString("image", "").replace("150x150", "500x500")
        val duration = o.optString("duration", "0").toIntOrNull() ?: 0
        val streamUrl = bestStreamUrl(o)
        return Song(id, title, artist, album, image.ifBlank { null }, duration, streamUrl, "jiosaavn")
    }

    private fun htmlDecode(s: String): String =
        s.replace("&amp;", "&")
            .replace("&#039;", "'")
            .replace("&quot;", "\"")
            .replace("&lt;", "<")
            .replace("&gt;", ">")
            .trim()
}
